datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id            String      @id @default(uuid())
  name          String      @unique
  description   String?
  color         String      @default("#6366f1")
  isSuperadmin  Boolean     @default(false) @map("is_superadmin")
  permissions   Json        @default("{}")
  createdAt     DateTime    @default(now()) @map("created_at")
  staffUsers    StaffUser[]

  @@map("roles")
}

model StaffUser {
  id                 String           @id @default(uuid())
  name               String
  email              String           @unique
  password           String
  avatarUrl          String?          @map("avatar_url")
  roleId             String?          @map("role_id")
  role               Role?            @relation(fields: [roleId], references: [id])
  isActive           Boolean          @default(true) @map("is_active")
  createdAt          DateTime         @default(now()) @map("created_at")
  scannedAttendance  Attendance[]     @relation("ScannedBy")
  overrideAttendance Attendance[]     @relation("OverrideBy")
  createdTrainings   Training[]
  auditLogs          AttendanceAudit[]
  translations       Translation[]
  homeworks          Homework[]
  homeworkGrades     HomeworkGrade[]
  activityScores     ActivityScore[]

  @@map("staff_users")
}

model Training {
  id                   String                @id @default(uuid())
  name                 String
  description          String?
  color                String                @default("#3B82F6")
  icon                 String                @default("book")
  startDate            DateTime              @map("start_date") @db.Date
  endDate              DateTime              @map("end_date") @db.Date
  scheduleDays         Int[]                 @map("schedule_days")
  scheduleTime         String                @map("schedule_time")
  status               String                @default("upcoming")
  attendanceThreshold  Int                   @default(80) @map("attendance_threshold")
  lateThresholdMinutes Int?                  @map("late_threshold_minutes")
  scanWindowBefore     Int?                  @map("scan_window_before") // minutes before session; null = use system default
  scanWindowAfter      Int?                  @map("scan_window_after")  // minutes after session; null = use system default
  categoryId           String?               @map("category_id")
  category             TrainingCategory?     @relation(fields: [categoryId], references: [id])
  createdById          String?               @map("created_by")
  createdBy            StaffUser?            @relation(fields: [createdById], references: [id])
  createdAt            DateTime              @default(now()) @map("created_at")
  sessions             Session[]
  trainingParticipants TrainingParticipant[]
  homeworks            Homework[]

  @@map("trainings")
}

model TrainingCategory {
  id        String     @id @default(uuid())
  nameUz    String     @map("name_uz")
  nameRu    String?    @map("name_ru")
  nameEn    String?    @map("name_en")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  trainings Training[]

  @@map("training_categories")
}

model Translation {
  id          String     @id @default(uuid())
  key         String
  language    String
  value       String
  updatedAt   DateTime   @updatedAt @map("updated_at")
  updatedById String?    @map("updated_by")
  updatedBy   StaffUser? @relation(fields: [updatedById], references: [id])

  @@unique([key, language])
  @@map("translations")
}

model Session {
  id               String       @id @default(uuid())
  trainingId       String       @map("training_id")
  training         Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  sessionNumber    Int          @map("session_number")
  sessionDate      String       @map("session_date")          // "YYYY-MM-DD" plain string — no timezone
  sessionTime      String       @map("session_time")
  status           String       @default("upcoming") // kept for schema compatibility; state is derived at runtime
  isCancelled      Boolean      @default(false) @map("is_cancelled")
  forceClosed      Boolean      @default(false) @map("force_closed")
  cancelledAt      DateTime?    @map("cancelled_at")
  cancelledById    String?      @map("cancelled_by")
  forceClosedAt    DateTime?    @map("force_closed_at")
  forceClosedById  String?      @map("force_closed_by")
  createdAt        DateTime        @default(now()) @map("created_at")
  attendance       Attendance[]
  activityScores   ActivityScore[]

  @@unique([trainingId, sessionNumber])
  @@index([sessionDate])
  @@index([trainingId, sessionDate])
  @@map("sessions")
}

model Participant {
  id                   String                @id @default(uuid())
  fullName             String                @map("full_name")
  phone                String?
  email                String?
  photoUrl             String?               @map("photo_url")
  qrToken              String                @unique @default(uuid()) @map("qr_token")
  isBlocked            Boolean               @default(false) @map("is_blocked")
  blockedAt            DateTime?             @map("blocked_at")
  blockedReason        String?               @map("blocked_reason")
  lastSeenAt           DateTime?             @map("last_seen_at")
  phoneVerifiedAt      DateTime?             @map("phone_verified_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  trainingParticipants TrainingParticipant[]
  attendance           Attendance[]
  auth                 ParticipantAuth?
  homeworkSubmissions  HomeworkSubmission[]
  telegramLink         TelegramLink?
  telegramLinkCode     TelegramLinkCode?
  activityScores       ActivityScore[]
  telegramMessages     TelegramMessage[]
  phoneLoginTokens     PhoneLoginToken[]

  @@map("participants")
}

model TrainingParticipant {
  trainingId    String      @map("training_id")
  participantId String      @map("participant_id")
  training      Training    @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  enrolledAt    DateTime    @default(now()) @map("enrolled_at")

  @@id([trainingId, participantId])
  @@map("training_participants")
}

model Attendance {
  id               String           @id @default(uuid())
  sessionId        String           @map("session_id")
  participantId    String           @map("participant_id")
  session          Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant      Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  status           String
  method           String           @default("system") // "system" | "qr" | "manual"
  scannedAt        DateTime?        @map("scanned_at")
  scannedById      String?          @map("scanned_by")
  scannedBy        StaffUser?       @relation("ScannedBy", fields: [scannedById], references: [id])
  note             String?
  overrideById     String?          @map("override_by")
  overrideBy       StaffUser?       @relation("OverrideBy", fields: [overrideById], references: [id])
  overrideAt       DateTime?        @map("override_at")
  syncedFromOffline Boolean         @default(false) @map("synced_from_offline")
  auditLogs        AttendanceAudit[]

  @@unique([sessionId, participantId])
  @@map("attendance")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}

model ParticipantAuth {
  id            String      @id @default(uuid())
  participantId String      @unique @map("participant_id")
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  username      String      @unique
  passwordHash  String      @map("password_hash")
  lastLoginAt   DateTime?   @map("last_login_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("participant_auth")
}

model AttendanceAudit {
  id           String      @id @default(uuid())
  attendanceId String      @map("attendance_id")
  attendance   Attendance  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  changedById  String?     @map("changed_by")
  changedBy    StaffUser?  @relation(fields: [changedById], references: [id])
  oldStatus    String?     @map("old_status")
  newStatus    String?     @map("new_status")
  reason       String?
  changedAt    DateTime    @default(now()) @map("changed_at")

  @@map("attendance_audit")
}

model Homework {
  id          String               @id @default(uuid())
  trainingId  String               @map("training_id")
  training    Training             @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   String?              @map("start_date") // "YYYY-MM-DD" plain string, nullable
  dueDate     String?              @map("due_date")   // "YYYY-MM-DD" plain string, nullable
  maxScore    Int                  @default(100) @map("max_score") // always 100 — grading is by percent
  createdById String?              @map("created_by")
  createdBy   StaffUser?           @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now()) @map("created_at")
  submissions HomeworkSubmission[]

  @@map("homeworks")
}

model HomeworkSubmission {
  id            String         @id @default(uuid())
  homeworkId    String         @map("homework_id")
  homework      Homework       @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  participantId String         @map("participant_id")
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  text          String?
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  grade         HomeworkGrade?
  files         HomeworkFile[]
  events        SubmissionEvent[]

  @@unique([homeworkId, participantId])
  @@map("homework_submissions")
}

model HomeworkFile {
  id              String             @id @default(uuid())
  submissionId    String             @map("submission_id")
  submission      HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileName        String             @map("file_name")
  fileType        String             @map("file_type")   // "document" | "audio" | "video" | "voice" | "photo"
  fileSizeBytes   Int?               @map("file_size_bytes")
  storageUrl      String?            @map("storage_url") // R2 public URL (null until uploaded)
  telegramFileId  String?            @map("telegram_file_id") // Telegram file_id for re-download
  uploadedAt      DateTime           @default(now()) @map("uploaded_at")

  @@map("homework_files")
}

model HomeworkGrade {
  id           String             @id @default(uuid())
  submissionId String             @unique @map("submission_id")
  submission   HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score        Int
  feedback     String?
  gradedById   String?            @map("graded_by")
  gradedBy     StaffUser?         @relation(fields: [gradedById], references: [id])
  gradedAt     DateTime           @default(now()) @map("graded_at")

  @@map("homework_grades")
}

enum SubmissionEventType {
  SUBMITTED
  TEXT_EDITED
  FILE_ADDED
  FILE_DELETED
  RESUBMITTED
  GRADED
  GRADE_EDITED
  GRADE_DELETED
}

model SubmissionEvent {
  id           String              @id @default(cuid())
  submissionId String              @map("submission_id")
  submission   HomeworkSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actorId      String              @map("actor_id")   // StaffUser.id or Participant.id (string, no FK so both types work)
  actorRole    String              @map("actor_role")  // "participant" | "curator" | "admin"
  actorName    String              @map("actor_name")  // denormalized display name
  eventType    SubmissionEventType @map("event_type")
  meta         Json?               // { filename, size, oldScore, newScore, text, … }
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([submissionId])
  @@map("submission_events")
}

model ActivityScore {
  id            String      @id @default(uuid())
  sessionId     String      @map("session_id")
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId String      @map("participant_id")
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  score         Int         // e.g. 0-100
  note          String?
  enteredById   String?     @map("entered_by")
  enteredBy     StaffUser?  @relation(fields: [enteredById], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([sessionId, participantId])
  @@map("activity_scores")
}

model TelegramMessage {
  id             String      @id @default(uuid())
  chatId         BigInt      @map("chat_id")
  participantId  String?     @map("participant_id")
  participant    Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  direction      String      // "in" | "out"
  text           String?
  messageType    String      @default("text") @map("message_type") // "text"|"document"|"audio"|"video"|"voice"|"photo"
  telegramFileId String?     @map("telegram_file_id")
  fileName       String?     @map("file_name")
  fileSizeBytes  Int?        @map("file_size_bytes")
  telegramMsgId  Int?        @map("telegram_msg_id")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([chatId])
  @@index([participantId])
  @@map("telegram_messages")
}

model TelegramLink {
  id                  String      @id @default(uuid())
  participantId       String      @unique @map("participant_id")
  participant         Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  chatId              BigInt      @map("chat_id")
  username            String?
  firstName           String?     @map("first_name")
  verifiedPhone       String?     @map("verified_phone")       // E.164, set on contact-share
  verifiedByContact   Boolean     @default(false) @map("verified_by_contact")
  linkedAt            DateTime    @default(now()) @map("linked_at")

  @@map("telegram_links")
}

model BotAuthLog {
  id             String   @id @default(cuid())
  telegramUserId BigInt   @map("telegram_user_id")
  chatId         BigInt   @map("chat_id")
  phone          String?
  event          String   // see BotAuthEvent in src/lib/botAuth.ts
  meta           Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([telegramUserId])
  @@index([phone])
  @@map("bot_auth_log")
}

model TelegramLinkCode {
  id            String      @id @default(uuid())
  participantId String      @unique @map("participant_id")
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  code          String      @unique
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("telegram_link_codes")
}

model PhoneLoginToken {
  id            String      @id @default(uuid())
  participantId String      @map("participant_id")
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  token         String      @unique
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("phone_login_tokens")
}
